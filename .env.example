# Stacker Configuration
# Copy this file to .env and fill in your values

# ── AI Provider ──────────────────────────────────────────
# Get a free Groq API key at: https://console.groq.com
GROQ_API_KEY=gsk_your_key_here

# Provider selection (currently: groq)
STACKER_PROVIDER=groq

# ── Model Selection ───────────────────────────────────────
# Analysis model — used to analyze project structure
# Recommended: deepseek-r1-distill-llama-70b (fast, accurate)
STACKER_ANALYSIS_MODEL=qwen/qwen3-32b

# Reasoning model — used to generate improvement recommendations
# Recommended: llama-3.3-70b-versatile (best reasoning)
STACKER_REASONING_MODEL=llama-3.3-70b-versatile

# ── Behavior ──────────────────────────────────────────────
# Skip AI analysis and use rule engine only
STACKER_SKIP_AI=false

# Enable/disable response caching
STACKER_CACHE=true

# Number of API call retries on failure
STACKER_RETRIES=2

# API call timeout in milliseconds
STACKER_TIMEOUT=30000

# Enable verbose/debug output
STACKER_VERBOSE=false
