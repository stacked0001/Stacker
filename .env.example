# Stacker Configuration
# Optional local CLI overrides. Most users do not need this file.

# Provider selection. AI calls are routed through the Stacker proxy.
STACKER_PROVIDER=groq

# Analysis model used to analyze project structure.
STACKER_ANALYSIS_MODEL=moonshotai/kimi-k2-instruct

# Reasoning model used to generate improvement recommendations.
STACKER_REASONING_MODEL=openai/gpt-oss-120b

# Skip AI analysis and use rule engine only.
STACKER_SKIP_AI=false

# Enable/disable response caching.
STACKER_CACHE=true

# Number of API call retries on failure.
STACKER_RETRIES=2

# API call timeout in milliseconds.
STACKER_TIMEOUT=30000

# Enable verbose/debug output.
STACKER_VERBOSE=false
